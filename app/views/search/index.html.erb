<% current_query = @search.query %>
<% content_for :title, current_query.present? ? "Search: #{current_query}" : "Search" %>

<div
  class="search-page"
  data-controller="pagefind-search"
  data-pagefind-ignore="all"
  data-pagefind-search-query-value="<%= current_query %>"
>
  <div class="page-shell">
    <header class="page-hero search-hero">
      <div>
        <p class="page-eyebrow">Archive search</p>
        <h1 class="page-title">Search illustrations, novels, editions, illustrators, and motif tags.</h1>
        <p class="page-lead">Use the archive-wide search to connect keywords like <em>elephant</em>, <em>woman</em>, or <em>ship</em> to images, books, and artists.</p>

        <% if current_query.present? %>
          <p class="search-summary">Results for <strong><%= current_query %></strong></p>

          <div
            class="meta-chip-row search-result-jumps <%= "is-hidden" unless @search.illustrations.any? || @search.novels.any? || @search.editions.any? %>"
            aria-label="Jump to search result sections"
            data-pagefind-search-target="jumpChips"
          >
            <% if @search.illustrations.any? %>
              <%= link_to pluralize(@search.illustration_count, "illustration"), "#search-illustrations", class: "meta-chip meta-chip-link" %>
            <% end %>
            <% if @search.novels.any? %>
              <%= link_to pluralize(@search.novel_count, "novel"), "#search-novels", class: "meta-chip meta-chip-link" %>
            <% end %>
            <% if @search.editions.any? %>
              <%= link_to pluralize(@search.edition_count, "edition"), "#search-editions", class: "meta-chip meta-chip-link" %>
            <% end %>
          </div>
        <% else %>
          <div
            class="meta-chip-row search-result-jumps is-hidden"
            aria-label="Jump to search result sections"
            data-pagefind-search-target="jumpChips"
          ></div>
        <% end %>
      </div>

      <aside class="search-hero-panel">
        <% if current_query.present? %>
          <p class="search-hero-label">Current query</p>
          <h2><%= current_query %></h2>
          <p>Results are grouped by archive type so you can move directly from a motif or keyword to novels, editions, or individual illustrations.</p>
        <% else %>
          <p class="search-hero-label">How it works</p>
          <h2>Search from the top bar</h2>
          <p>Enter a motif, title, illustrator, or keyword. The results page pulls together records across the whole archive.</p>
        <% end %>
      </aside>
    </header>

    <div class="search-pagefind-shell" data-pagefind-search-target="shell" hidden>
      <section class="empty-state search-empty-state search-status-panel" data-pagefind-search-target="status" hidden></section>

      <section class="search-section surface-panel" id="pagefind-search-illustrations" data-pagefind-search-target="illustrationsSection" hidden>
        <div class="section-heading search-section-heading">
          <div>
            <p class="page-eyebrow">Results</p>
            <h2>Illustrations</h2>
          </div>
          <p><span data-pagefind-search-target="illustrationsCount">0</span> matches</p>
        </div>

        <div class="search-card-grid search-card-grid--illustrations" data-pagefind-search-target="illustrationsResults"></div>

        <div class="search-pagination" data-pagefind-search-target="illustrationsMore" hidden>
          <button
            type="button"
            class="ui-button ui-button--secondary search-load-more"
            data-action="pagefind-search#loadMore"
            data-pagefind-search-type-param="illustrations"
          >
            Load more illustrations
          </button>
        </div>
      </section>

      <section class="search-section surface-panel" id="pagefind-search-novels" data-pagefind-search-target="novelsSection" hidden>
        <div class="section-heading search-section-heading">
          <div>
            <p class="page-eyebrow">Results</p>
            <h2>Novels</h2>
          </div>
          <p><span data-pagefind-search-target="novelsCount">0</span> matches</p>
        </div>

        <div class="search-card-grid search-card-grid--novels" data-pagefind-search-target="novelsResults"></div>

        <div class="search-pagination" data-pagefind-search-target="novelsMore" hidden>
          <button
            type="button"
            class="ui-button ui-button--secondary search-load-more"
            data-action="pagefind-search#loadMore"
            data-pagefind-search-type-param="novels"
          >
            Load more novels
          </button>
        </div>
      </section>

      <section class="search-section surface-panel" id="pagefind-search-editions" data-pagefind-search-target="editionsSection" hidden>
        <div class="section-heading search-section-heading">
          <div>
            <p class="page-eyebrow">Results</p>
            <h2>Editions</h2>
          </div>
          <p><span data-pagefind-search-target="editionsCount">0</span> matches</p>
        </div>

        <div class="search-list" data-pagefind-search-target="editionsResults"></div>

        <div class="search-pagination" data-pagefind-search-target="editionsMore" hidden>
          <button
            type="button"
            class="ui-button ui-button--secondary search-load-more"
            data-action="pagefind-search#loadMore"
            data-pagefind-search-type-param="editions"
          >
            Load more editions
          </button>
        </div>
      </section>

      <section class="search-section surface-panel" data-pagefind-search-target="illustratorsSection" hidden>
        <div class="section-heading search-section-heading">
          <div>
            <p class="page-eyebrow">Results</p>
            <h2>Illustrators</h2>
          </div>
          <p><span data-pagefind-search-target="illustratorsCount">0</span> matches</p>
        </div>

        <div class="search-list" data-pagefind-search-target="illustratorsResults"></div>

        <div class="search-pagination" data-pagefind-search-target="illustratorsMore" hidden>
          <button
            type="button"
            class="ui-button ui-button--secondary search-load-more"
            data-action="pagefind-search#loadMore"
            data-pagefind-search-type-param="illustrators"
          >
            Load more illustrators
          </button>
        </div>
      </section>
    </div>

    <div class="search-fallback" data-pagefind-search-target="fallback">
      <% if @search.blank? %>
        <section class="empty-state search-empty-state">
          <p>Enter a search term in the header search bar to browse illustrations, novels, illustrators, and archive tags.</p>
        </section>
      <% elsif !@search.any_results? %>
        <section class="empty-state search-empty-state">
          <p>No results were found for <strong><%= @search.query %></strong>.</p>
        </section>
      <% else %>
        <% if @search.illustrations.any? %>
          <section class="search-section surface-panel" id="search-illustrations">
            <div class="section-heading search-section-heading">
              <div>
                <p class="page-eyebrow">Results</p>
                <h2>Illustrations</h2>
              </div>
              <p><%= number_with_delimiter(@search.illustration_count) %> matches</p>
            </div>

            <div class="search-card-grid search-card-grid--illustrations" data-controller="photoswipe">
              <% @search.illustrations.each do |illustration| %>
                <% edition = illustration.edition %>
                <% novel = edition&.novel %>
                <% next if edition.blank? || novel.blank? %>
                <% preview_image = illustration.display_image_source(style: :original) %>
                <article class="search-card search-card--illustration">
                  <% if preview_image.present? %>
                    <div class="search-card-image-frame">
                      <%= zoomable_image_link preview_image, link_options: { class: "search-card-image-link" } do %>
                        <%= image_tag preview_image, alt: illustration.name, class: "search-card-image", loading: "lazy", decoding: "async" %>
                      <% end %>
                    </div>
                  <% end %>
                  <div class="search-card-body">
                    <p class="search-card-kicker">Illustration</p>
                    <h3><%= link_to illustration.name.presence || "Untitled illustration", illustration_path(illustration) %></h3>
                    <p><strong><%= novel.name %></strong></p>
                    <% if illustration.illustrator&.name.present? %>
                      <p><%= illustration.illustrator.name %></p>
                    <% elsif illustration.artist.present? %>
                      <p><%= illustration.artist %></p>
                    <% end %>
                  </div>
                </article>
              <% end %>
            </div>

            <div class="search-pagination">
              <%= paginate @search.illustrations, params: { search: @search.query } %>
            </div>
          </section>
        <% end %>

        <% if @search.novels.any? %>
          <section class="search-section surface-panel" id="search-novels">
            <div class="section-heading search-section-heading">
              <div>
                <p class="page-eyebrow">Results</p>
                <h2>Novels</h2>
              </div>
              <p><%= number_with_delimiter(@search.novel_count) %> matches</p>
            </div>

            <div class="search-card-grid search-card-grid--novels">
              <% @search.novels.each do |novel| %>
                <% cover_source = novel.display_cover_source(style: :original) %>
                <%= link_to novel_path(novel), class: "search-card" do %>
                  <% if cover_source.present? %>
                    <div class="search-card-image-frame">
                      <%= image_tag cover_source, alt: novel.name, class: "search-card-image", loading: "lazy", decoding: "async" %>
                    </div>
                  <% end %>
                  <div class="search-card-body">
                    <p class="search-card-kicker">Novel</p>
                    <h3><%= novel.name %></h3>
                    <% if (excerpt = plain_text_excerpt(novel.description, length: 180)).present? %>
                      <p><%= excerpt %></p>
                    <% end %>
                  </div>
                <% end %>
              <% end %>
            </div>
          </section>
        <% end %>

        <% if @search.editions.any? %>
          <section class="search-section surface-panel" id="search-editions">
            <div class="section-heading search-section-heading">
              <div>
                <p class="page-eyebrow">Results</p>
                <h2>Editions</h2>
              </div>
              <p><%= number_with_delimiter(@search.edition_count) %> matches</p>
            </div>

            <div class="search-list">
              <% @search.editions.each do |edition| %>
                <%= link_to edition_path(edition), class: "search-list-item" do %>
                  <div>
                    <p class="search-card-kicker">Edition</p>
                    <h3><%= edition.display_title %></h3>
                    <p><strong><%= edition.novel.name %></strong></p>
                    <% if (citation = edition.publication_citation) %>
                      <p><%= citation %></p>
                    <% end %>
                  </div>
                <% end %>
              <% end %>
            </div>
          </section>
        <% end %>

        <% if @search.illustrators.any? %>
          <section class="search-section surface-panel">
            <div class="section-heading search-section-heading">
              <div>
                <p class="page-eyebrow">Results</p>
                <h2>Illustrators</h2>
              </div>
              <p><%= number_with_delimiter(@search.illustrator_count) %> matches</p>
            </div>

            <div class="search-list">
              <% @search.illustrators.each do |illustrator| %>
                <%= link_to illustrator_path(illustrator), class: "search-list-item" do %>
                  <div>
                    <p class="search-card-kicker">Illustrator</p>
                    <h3><%= illustrator.name %></h3>
                    <% if (excerpt = plain_text_excerpt(illustrator.bio, length: 180)).present? %>
                      <p><%= excerpt %></p>
                    <% end %>
                  </div>
                <% end %>
              <% end %>
            </div>
          </section>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
