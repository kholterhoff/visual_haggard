<div class="editions-page">
  <div class="editions-header">
    <h1>Editions</h1>
    <p class="editions-intro">
      This page provides a comprehensive list of all editions of H. Rider Haggard's novels in the Visual Haggard database. 
      Each entry includes publication details and links to view more information about the edition and its illustrations.
    </p>
  </div>

  <div class="editions-list">
    <% current_novel = nil %>
    <% @editions.each do |edition| %>
      <% if current_novel != edition.novel.name %>
        <% current_novel = edition.novel.name %>
        <div class="novel-section">
          <h2 class="novel-title"><%= link_to current_novel, novel_path(edition.novel) %></h2>
        </div>
      <% end %>
      
      <div class="edition-entry">
        <div class="edition-info">
          <h3 class="edition-name">
            <%= link_to edition.name, edition_path(edition) %>
          </h3>
          <div class="edition-details">
            <% if edition.publisher.present? %>
              <span class="publisher"><strong>Publisher:</strong> <%= edition.publisher %></span>
            <% end %>
            <% if edition.publication_city.present? %>
              <span class="publication-city"><strong>City:</strong> <%= edition.publication_city %></span>
            <% end %>
            <% if edition.publication_date.present? %>
              <span class="publication-date"><strong>Date:</strong> <%= edition.publication_date %></span>
            <% end %>
          </div>
          <% if edition.illustrations.any? %>
            <div class="illustration-count">
              <%= pluralize(edition.illustrations.count, 'illustration') %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
