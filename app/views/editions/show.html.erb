<% content_for :title, @edition.display_title %>
<%
  cover_source = @edition.display_cover_source(style: :original)
  lead_illustration_source = nil

  if cover_source.blank?
    lead_illustration = @edition.illustrations.find do |illustration|
      illustration.display_image_source(style: :original).present?
    end
    lead_illustration_source = lead_illustration&.display_image_source(style: :original)
  end

  pagefind_image_source = cover_source.presence || lead_illustration_source
%>

<div class="edition-page" data-pagefind-body>
  <%= pagefind_record_data(
    filters: { record_type: "edition" },
    meta: {
      record_type: "edition",
      title: @edition.display_title,
      edition_title: @edition.display_title,
      novel_name: @edition.novel.name,
      image: public_asset_url(pagefind_image_source),
      summary: [@edition.publication_citation, @edition.source].compact.join(" "),
      publication_citation: @edition.publication_citation
    },
    body: [
      @edition.novel.name,
      @edition.publisher,
      @edition.publication_date,
      @edition.publication_city,
      @edition.source
    ]
  ) %>

  <div class="page-shell">
    <section class="record-header record-header--breadcrumbs-only">
      <p class="record-breadcrumbs">
        <%= link_to "Novels", novels_path %>
        /
        <%= linked_novel_title(@edition.novel) %>
        /
        Edition
      </p>
    </section>

    <h1 class="sr-only"><%= @edition.display_title %></h1>

    <section class="record-layout">
      <div class="record-figure">
        <% if cover_source.present? %>
          <%= image_tag cover_source, alt: @edition.display_title %>
        <% elsif lead_illustration_source.present? %>
          <div data-controller="photoswipe">
            <%= zoomable_image_link lead_illustration_source,
              alt: @edition.display_title do %>
              <%= image_tag lead_illustration_source, alt: @edition.display_title %>
            <% end %>
          </div>
        <% else %>
          <div class="record-placeholder">No image available</div>
        <% end %>
      </div>

      <aside class="record-meta">
        <dl>
          <dt>Edition</dt>
          <dd><%= @edition.display_title %></dd>

          <dt>Novel</dt>
          <dd><%= linked_novel_title(@edition.novel) %></dd>

          <% if @edition.publisher.present? && @edition.publisher != "Unknown" %>
            <dt>Published by</dt>
            <dd><%= @edition.publisher %></dd>
          <% end %>

          <% if @edition.publication_date.present? && @edition.publication_date != "Unknown" %>
            <dt>Published</dt>
            <dd><%= @edition.publication_date %></dd>
          <% end %>

          <% if @edition.publication_city.present? && @edition.publication_city != "Unknown" %>
            <dt>Publication City</dt>
            <dd><%= @edition.publication_city %></dd>
          <% end %>

          <% if @edition.source.present? && @edition.source != "Unknown" %>
            <dt>Edition Source</dt>
            <dd><%= @edition.source %></dd>
          <% end %>
        </dl>
      </aside>
    </section>

    <% if @edition.illustrations.any? %>
      <section class="record-gallery">
        <div class="section-heading">
          <div>
            <p class="page-eyebrow">Edition contents</p>
            <h2>Illustrations in this edition</h2>
          </div>
        </div>

        <div class="record-gallery-grid" data-controller="photoswipe">
          <% @edition.illustrations.each do |illustration| %>
            <article class="record-gallery-card">
              <% if illustration.display_image_source(style: :original).present? %>
                <%= zoomable_image_link illustration.display_image_source(style: :original),
                  link_options: { class: "record-gallery-image-link" } do %>
                  <%= image_tag illustration.display_image_source(style: :original), alt: illustration.name, loading: "lazy", decoding: "async" %>
                <% end %>
              <% else %>
                <div class="record-gallery-placeholder">No image</div>
              <% end %>

              <div class="record-gallery-card-copy">
                <%= link_to illustration.name.presence || "Untitled illustration", illustration_path(illustration) %>
              </div>
            </article>
          <% end %>
        </div>
      </section>
    <% end %>

    <div class="record-back-link">
      <%= link_to safe_join(["Back to ".html_safe, work_title(@edition.novel.name)]), novel_path(@edition.novel, anchor: "edition-archive"), class: "ui-button ui-button--secondary" %>
    </div>
  </div>
</div>
