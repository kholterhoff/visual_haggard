<% content_for :title, "Editor's Statement" %>

<div
  class="prose-page editor-statement-page"
  data-controller="back-to-top"
  data-back-to-top-scroll-threshold-value="720"
>
  <div class="prose-shell">
    <article class="prose-article">
      <header class="prose-header">
        <p class="page-eyebrow">Editor's Statement</p>
        <h1 class="page-title">About the Archive</h1>
      </header>

      <div class="prose-content editor-statement-content">
        <%= render "editors_statement_content" %>
      </div>
    </article>

    <button
      type="button"
      class="ui-button ui-button--secondary back-to-top-button"
      data-back-to-top-target="button"
      data-action="back-to-top#scroll"
      hidden
    >
      Back to top
    </button>
  </div>
</div>
