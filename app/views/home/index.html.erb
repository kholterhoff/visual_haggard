<% content_for :title, "Visual Haggard" %>

<div class="home-page" data-controller="motion-toggle">
  <section
    class="home-cover-wall"
    data-controller="reels"
    data-reels-ready="false"
  >
    <button
      type="button"
      class="home-motion-toggle"
      data-motion-toggle-target="button"
      data-action="motion-toggle#toggle"
      aria-pressed="false"
    >
      Pause motion
    </button>
    <div class="home-cover-reels">
      <% @hero_cover_reels.each_with_index do |reel, reel_index| %>
        <% direction_class = reel_index.even? ? "is-ascending" : "is-descending" %>
        <div
          class="home-cover-reel <%= direction_class %>"
          data-reels-target="reel"
          style="--reel-duration: <%= 24 + (reel_index * 4) %>s; --reel-delay: -<%= (reel_index * 2.6).round(1) %>s;"
        >
          <div class="home-cover-reel-track">
            <% 2.times do |sequence_index| %>
              <div class="home-cover-reel-sequence" data-reels-target="sequence" <%= %(aria-hidden="true") if sequence_index.positive? %>>
                <% reel.each do |edition| %>
                  <% cover_source = edition.display_cover_source(style: :original) %>
                  <% link_options = { class: "home-cover-tile" } %>
                  <% if sequence_index.positive? %>
                    <% link_options[:tabindex] = "-1" %>
                    <% link_options["aria-hidden"] = "true" %>
                  <% end %>
                  <% tile_image = image_tag cover_source,
                    alt: "#{edition.novel.name} - #{edition.display_title}",
                    class: "home-cover-tile-image",
                    loading: sequence_index.zero? ? "eager" : "lazy",
                    decoding: "async",
                    data: (sequence_index.zero? ? { reels_target: "image" } : {}) %>
                  <%= link_to tile_image, edition_path(edition), link_options %>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </section>

  <div class="page-shell home-content-shell">
    <section class="home-guides">
      <article class="surface-panel home-guide-card home-guide-card--archive">
        <p class="page-eyebrow">What is Visual Haggard?</p>
        <h2>Read H. Rider Haggard through images</h2>
        <p>Visual Haggard is a digital archive of the illustrations that accompanied the fiction of H. Rider Haggard (1856–1925). Across roughly fifty novels, Haggard's texts were lavishly illustrated—often repeatedly, in different editions and by different artists. Illustration was central to the way readers encountered these romances in the nineteenth century, and this archive works to restore that visual dimension for contemporary audiences.</p>
      </article>

      <aside class="home-highlight-card">
        <div class="home-highlight-stat">
          <strong><%= number_with_delimiter(@illustration_count) %></strong>
          <span>images cataloged</span>
        </div>
        <p>Browse by novel or illustrator using the navigation above, or use the search bar to find images by subject, scene, or character.</p>
      </aside>
    </section>

    <section class="home-feature-section">
      <div class="section-heading">
        <div>
          <p class="page-eyebrow">Featured edition</p>
          <h2>Start with a single edition</h2>
        </div>
        <%= link_to "Browse novels", novels_path, class: "section-link" %>
      </div>

      <div
        class="surface-panel home-feature-carousel"
        data-controller="rotator"
        data-rotator-interval-value="6200"
        data-action="mouseenter->rotator#pause mouseleave->rotator#resume focusin->rotator#pause focusout->rotator#resume"
        aria-roledescription="carousel"
        aria-label="Featured edition carousel"
      >
        <% @featured_editions.each_with_index do |edition, index| %>
          <article
            class="home-feature-slide <%= "is-active" if index.zero? %>"
            data-rotator-target="slide"
            role="group"
            aria-roledescription="slide"
            aria-label="<%= "#{index + 1} of #{@featured_editions.size}" %>"
            aria-hidden="<%= index.zero? ? "false" : "true" %>"
          >
            <div class="home-feature-slide-visual">
              <% feature_image = image_tag edition.display_cover_source(style: :original),
                alt: "#{edition.novel.name} - #{edition.display_title}",
                class: "home-feature-image",
                loading: index.zero? ? "eager" : "lazy",
                decoding: "async" %>
              <%= link_to feature_image, edition_path(edition), class: "home-feature-slide-cover" %>
            </div>

            <div class="home-feature-slide-copy">
              <p class="home-feature-label">Edition</p>
              <h3 class="home-feature-novel-title"><%= linked_novel_title(edition.novel) %></h3>
              <p class="home-feature-edition-title"><%= link_to edition.display_title, edition_path(edition) %></p>
              <p class="home-feature-description">
                <%= edition.publication_citation.presence || "Follow this edition into its novel record, related illustrations, and bibliographic context." %>
              </p>
              <div class="page-actions">
                <%= link_to "View this edition", edition_path(edition), class: "ui-button" %>
                <%= link_to "View other editions", novel_path(edition.novel, anchor: "edition-archive"), class: "ui-button ui-button--secondary" %>
              </div>
            </div>
          </article>
        <% end %>

        <% if @featured_editions.many? %>
          <div class="home-feature-controls">
            <button type="button" class="home-feature-arrow" data-action="rotator#previous" aria-label="Show previous featured edition">
              <span aria-hidden="true">&larr;</span>
            </button>

            <div class="home-feature-dots" aria-label="Featured edition slides">
              <% @featured_editions.each_with_index do |edition, index| %>
                <button
                  type="button"
                  class="home-feature-dot <%= "is-active" if index.zero? %>"
                  data-rotator-target="dot"
                  data-action="rotator#select"
                  data-rotator-index-param="<%= index %>"
                  aria-label="Show <%= edition.novel.name %>, <%= edition.display_title %>"
                ></button>
              <% end %>
            </div>

            <button type="button" class="home-feature-pause" data-rotator-target="pauseButton" data-action="rotator#togglePause" aria-pressed="false">
              Pause motion
            </button>

            <button type="button" class="home-feature-arrow" data-action="rotator#next" aria-label="Show next featured edition">
              <span aria-hidden="true">&rarr;</span>
            </button>
          </div>
        <% end %>
      </div>
    </section>

    <section class="home-style-section">
      <% greiffenhagen = @style_illustrators.find { |illustrator| illustrator.name == "Maurice Greiffenhagen" } %>
      <% horton = @style_illustrators.find { |illustrator| illustrator.name == "W.T. Horton" } %>
      <div class="home-style-layout">
        <div class="home-style-text">
          <div class="section-heading">
            <div>
              <p class="page-eyebrow">Artist styles</p>
              <h2>Discover 19th and 20th century illustration styles</h2>
            </div>
          </div>

          <p class="home-section-intro">
            This archive makes stylistic contrast visible at a glance. <%= greiffenhagen.present? ? link_to("Maurice Greiffenhagen", illustrator_path(greiffenhagen)) : "Maurice Greiffenhagen" %> brings a lush Pre-Raphaelite sensibility to his illustrations. His romantic figures, theatrical compositions, and richly atmospheric palette give many of Haggard's most famous novels their visual identity. <%= horton.present? ? link_to("W.T. Horton", illustrator_path(horton)) : "W.T. Horton" %> works at the opposite extreme, stripping scenes down to stark black-and-white symbolist abstraction. Together they show how wide the range of Haggard illustration actually was.
          </p>
          <p class="home-section-intro">            
            Visual Haggard also makes it possible to compare how different artists interpreted the same story. <%= @style_novel.present? ? linked_novel_title(@style_novel) : work_title("King Solomon's Mines") %> alone has been illustrated by eleven different hands—from Victorian wood-engravers to mid-century paperback painters—each reimagining Haggard's Africa using a distinct visual language.
          </p>
        </div>

        <% if (left_style_edition = @style_editions[50]).present? %>
          <% left_style_image = image_tag left_style_edition.display_cover_source(style: :original), alt: "#{left_style_edition.novel.name} - #{left_style_edition.display_title}", class: "home-style-edition-image", loading: "lazy", decoding: "async" %>
          <div class="home-style-edition home-style-edition--lower-left">
            <figure class="home-style-figure">
              <%= link_to left_style_image, edition_path(left_style_edition), class: "home-style-edition-link" %>
              <figcaption class="biography-portrait-citation home-style-citation"><%= style_edition_citation(left_style_edition) %></figcaption>
            </figure>
          </div>
        <% end %>

        <% if (right_style_edition = @style_editions[109]).present? %>
          <% right_style_image = image_tag right_style_edition.display_cover_source(style: :original), alt: "#{right_style_edition.novel.name} - #{right_style_edition.display_title}", class: "home-style-edition-image", loading: "lazy", decoding: "async" %>
          <div class="home-style-edition home-style-edition--upper-right">
            <figure class="home-style-figure">
              <%= link_to right_style_image, edition_path(right_style_edition), class: "home-style-edition-link" %>
              <figcaption class="biography-portrait-citation home-style-citation"><%= style_edition_citation(right_style_edition) %></figcaption>
            </figure>
          </div>
        <% end %>
      </div>
    </section>

    <section class="home-timeline-section">
      <div class="surface-panel home-timeline-panel" data-controller="timeline-scroller">
        <div class="section-heading">
          <div>
            <p class="page-eyebrow">Edition timeline</p>
            <h2>Trace the archive's publication history</h2>
          </div>
        </div>

        <p class="home-section-intro">
          Scroll through the timeline to trace Haggard's publishing history, from the earliest editions in the archive to late twentieth-century revivals. Each marker links directly to an edition record.
        </p>

        <div class="home-timeline-toolbar">
          <p class="home-timeline-caption">Every dated edition in the archive, grouped by year.</p>
          <div class="home-timeline-controls">
            <button type="button" class="home-timeline-arrow" data-action="timeline-scroller#previous" aria-label="Scroll timeline backward">
              <span aria-hidden="true">&larr;</span>
            </button>
            <button type="button" class="home-timeline-arrow" data-action="timeline-scroller#next" aria-label="Scroll timeline forward">
              <span aria-hidden="true">&rarr;</span>
            </button>
          </div>
        </div>

        <div class="home-timeline-track" data-timeline-scroller-target="track">
          <% @timeline_groups.each do |group| %>
            <section class="home-timeline-year">
              <p class="home-timeline-year-label"><%= group[:year] %></p>
              <p class="home-timeline-year-count"><%= pluralize(group[:editions].size, "edition") %></p>
              <div class="home-timeline-stem"></div>
              <div class="home-timeline-markers">
                <% group[:editions].each do |edition| %>
                  <% marker_label = "#{edition.novel.name} — #{edition.display_title}" %>
                  <% tooltip_content = content_tag(:span, class: "home-timeline-tooltip", "aria-hidden": "true") do
                    safe_join([
                      content_tag(:strong, work_title(edition.novel.name)),
                      content_tag(:span, edition.display_title)
                    ])
                  end %>
                  <%= link_to safe_join([content_tag(:span, marker_label, class: "sr-only"), tooltip_content]),
                    edition_path(edition),
                    class: "home-timeline-marker",
                    "aria-label": "#{edition.novel.name}, #{edition.display_title}" %>
                <% end %>
              </div>
            </section>
          <% end %>
        </div>
      </div>
    </section>

    <section class="home-periodical-section">
      <div class="section-heading">
        <div>
          <p class="page-eyebrow">Periodicals</p>
          <h2>The importance of newspapers and magazines</h2>
        </div>
      </div>

      <div class="home-periodical-copy">
        <p>
          Visual Haggard treats periodicals as central, not peripheral. Illustrations circulated through newspapers and journals as powerful commercial and aesthetic objects, yet serial publications were printed on cheap paper, scattered across local collections, and survive far less reliably than bound books.
        </p>
        <p>
          Even when surviving scans are imperfect, these fragile serial appearances can matter more than later book editions — they are harder to locate, easier to lose, and often preserve illustrations that no bound volume reproduces. The archive treats them as essential evidence, not incidental supplements.        
        </p>
      </div>

      <div class="home-periodical-grid">
        <% @periodical_examples.each do |example| %>
          <% example_image = image_tag example[:image_source], alt: example[:title], class: "home-periodical-image", loading: "lazy", decoding: "async" %>
          <article class="surface-panel home-periodical-card">
            <%= link_to example_image, example[:path], class: "home-periodical-image-link" %>
            <div class="home-periodical-card-copy">
              <p class="home-style-kicker"><%= example[:label] %></p>
              <h3><%= linked_work_title(example[:title], example[:path]) %></h3>
              <p class="home-periodical-meta"><%= work_title(example[:subtitle]) %></p>
              <% if example[:detail].present? %>
                <p class="home-periodical-detail"><%= example[:detail] %></p>
              <% end %>
            </div>
          </article>
        <% end %>
      </div>
    </section>

    <section class="home-paperback-section">
      <div class="section-heading">
        <div>
          <p class="page-eyebrow">Science-fiction afterlives</p>
          <h2>Paperback and pulp reinventions carried Haggard into later genre markets</h2>
        </div>
      </div>

      <p class="home-section-intro">
        The archive tracks Haggard well beyond Victorian book illustration. Later speculative-fiction publishers and paperback houses recast these romances through saturated cover design, cinematic composition, and bold fantasy branding      
      </p>

      <div class="home-paperback-grid">
        <% @paperback_illustrators.each do |illustrator| %>
          <% representative_illustration = illustrator.representative_illustration(style: :original) %>
          <% representative_edition = representative_illustration&.edition %>
          <% paperback_image = image_tag illustrator.representative_image_source(style: :original), alt: illustrator.name, class: "home-paperback-image", loading: "lazy", decoding: "async" %>
          <article class="surface-panel home-paperback-card">
            <% if representative_edition.present? %>
              <%= link_to edition_path(representative_edition), class: "home-paperback-card-link" do %>
                <span class="home-paperback-image-link">
                  <%= paperback_image %>
                </span>
                <div class="home-paperback-card-copy">
                  <p class="home-style-kicker">Illustrator</p>
                  <h3><%= illustrator.name %></h3>
                  <p class="home-paperback-meta"><%= representative_edition.display_title %></p>
                  <p class="home-paperback-submeta"><%= work_title(representative_edition.novel.name) %></p>
                </div>
              <% end %>
            <% else %>
              <span class="home-paperback-image-link">
                <%= paperback_image %>
              </span>
              <div class="home-paperback-card-copy">
                <p class="home-style-kicker">Illustrator</p>
                <h3><%= illustrator.name %></h3>
              </div>
            <% end %>
          </article>
        <% end %>
      </div>
    </section>
  </div>
</div>
