<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for?(:title) ? yield(:title) + " - Visual Haggard" : "Visual Haggard" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta charset="utf-8">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "https://cdn.jsdelivr.net/npm/photoswipe@5.4.4/dist/photoswipe.css", "data-turbo-track": "reload" %>
    <%= yield :head if content_for?(:head) %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="<%= "#{controller_name}-#{action_name}" %>">
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <header class="site-header">
      <div class="site-header-shell">
        <div
          class="site-header-panel"
          data-controller="mobile-nav"
          data-action="click@window->mobile-nav#closeOnOutside keydown.esc@window->mobile-nav#close resize@window->mobile-nav#syncForViewport"
        >
          <%= link_to root_path, class: "site-brand", "aria-label": "Visual Haggard home" do %>
            <span class="site-brand-name">Visual Haggard</span>
          <% end %>

          <button
            type="button"
            class="site-menu-toggle"
            aria-label="Toggle navigation"
            aria-expanded="false"
            aria-controls="site-header-controls"
            data-mobile-nav-target="button"
            data-action="mobile-nav#toggle"
          >
            <span class="sr-only">Toggle navigation</span>
            <span class="site-menu-toggle-lines" aria-hidden="true">
              <span class="site-menu-toggle-line"></span>
              <span class="site-menu-toggle-line"></span>
              <span class="site-menu-toggle-line"></span>
            </span>
          </button>

          <div class="site-header-controls" id="site-header-controls" data-mobile-nav-target="panel">
            <nav class="site-nav" aria-label="Primary">
              <ul>
                <li><%= primary_nav_link_to "Novels", novels_path %></li>
                <li><%= primary_nav_link_to "Illustrators", illustrators_path %></li>
                <li><%= primary_nav_link_to "Biography", biography_path %></li>
                <li><%= primary_nav_link_to "Editor's Statement", editors_statement_path %></li>
              </ul>
            </nav>

            <%= form_with url: search_path, method: :get, class: "site-search", local: true do |form| %>
              <%= form.label :search, "Search the archive", class: "sr-only" %>
              <%= form.search_field :search,
                value: params[:search].presence || params[:q],
                class: "site-search-field",
                id: "search",
                placeholder: "Search the archive",
                aria: { label: "Search the archive" } %>
              <%= form.submit "Search", class: "site-search-submit" %>
            <% end %>
          </div>
        </div>
      </div>
    </header>

    <main class="site-main" id="main-content" tabindex="-1">
      <%= yield %>
    </main>

    <footer class="site-footer">
      <div class="site-footer-shell">
        <div class="site-footer-copy">
          <p>Visual Haggard is a digital archive created by <%= link_to "Kate Holterhoff", "https://kateholterhoff.com/", target: "_blank", rel: "noopener noreferrer" %> and dedicated to the illustrated works of H. Rider Haggard.</p>
          <div class="site-footer-mark">
            <%= image_tag "https://mirrors.creativecommons.org/presskit/buttons/88x31/svg/publicdomain.svg", alt: "Creative Commons Public Domain" %>
          </div>
        </div>

        <div class="site-footer-socials" aria-label="Kate Holterhoff social links">
          <%= link_to "https://twitter.com/KateHolterhoff", class: "site-footer-social-link", target: "_blank", rel: "noopener noreferrer", "aria-label": "Kate Holterhoff on Twitter" do %>
            <span class="sr-only">Twitter</span>
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M23.953 4.57a10 10 0 0 1-2.825.775a4.958 4.958 0 0 0 2.163-2.723a10.01 10.01 0 0 1-3.127 1.184a4.92 4.92 0 0 0-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 0 0-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 0 1-2.228-.616v.06a4.923 4.923 0 0 0 3.946 4.827a4.996 4.996 0 0 1-2.212.085a4.936 4.936 0 0 0 4.604 3.417a9.867 9.867 0 0 1-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 0 0 7.557 2.209c9.053 0 13.998-7.496 13.998-13.985c0-.21 0-.42-.015-.63A9.935 9.935 0 0 0 24 4.59z"/>
            </svg>
          <% end %>

          <%= link_to "https://linkedin.com/in/kateholterhoff", class: "site-footer-social-link", target: "_blank", rel: "noopener noreferrer", "aria-label": "Kate Holterhoff on LinkedIn" do %>
            <span class="sr-only">LinkedIn</span>
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037c-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85c3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065c0-1.138.92-2.063 2.063-2.063c1.14 0 2.064.925 2.064 2.063c0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          <% end %>

          <%= link_to "https://bsky.app/profile/kateholterhoff.bsky.social", class: "site-footer-social-link", target: "_blank", rel: "noopener noreferrer", "aria-label": "Kate Holterhoff on Bluesky" do %>
            <span class="sr-only">Bluesky</span>
            <svg viewBox="0 0 512 512" aria-hidden="true">
              <path d="M111.8 62.2C170.2 105.9 233 194.7 256 242.4c23-47.6 85.8-136.4 144.2-180.2c42.1-31.6 110.3-56 110.3 21.8c0 15.5-8.9 130.5-14.1 149.2C478.2 298 412 314.6 353.1 304.5c102.9 17.5 129.1 75.5 72.5 133.5c-107.4 110.2-154.3-27.6-166.3-62.9c-1.7-4.9-2.6-7.8-3.3-7.8s-1.6 3-3.3 7.8c-12 35.3-59 173.1-166.3 62.9c-56.5-58-30.4-116 72.5-133.5C100 314.6 33.8 298 15.7 233.1C10.4 214.4 1.5 99.4 1.5 83.9c0-77.8 68.2-53.4 110.3-21.8z"/>
            </svg>
          <% end %>

          <%= link_to "https://github.com/kholterhoff", class: "site-footer-social-link", target: "_blank", rel: "noopener noreferrer", "aria-label": "Kate Holterhoff on GitHub" do %>
            <span class="sr-only">GitHub</span>
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 0c-6.626 0-12 5.373-12 12c0 5.302 3.438 9.8 8.207 11.387c.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416c-.546-1.387-1.333-1.756-1.333-1.756c-1.089-.745.083-.729.083-.729c1.205.084 1.839 1.237 1.839 1.237c1.07 1.834 2.807 1.304 3.492.997c.107-.775.418-1.305.762-1.604c-2.665-.305-5.467-1.334-5.467-5.931c0-1.311.469-2.381 1.236-3.221c-.124-.303-.535-1.524.117-3.176c0 0 1.008-.322 3.301 1.23c.957-.266 1.983-.399 3.003-.404c1.02.005 2.047.138 3.006.404c2.291-1.552 3.297-1.23 3.297-1.23c.653 1.653.242 2.874.118 3.176c.77.84 1.235 1.911 1.235 3.221c0 4.609-2.807 5.624-5.479 5.921c.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576c4.765-1.589 8.199-6.086 8.199-11.386c0-6.627-5.373-12-12-12z"/>
            </svg>
          <% end %>
        </div>
      </div>
    </footer>
  </body>
</html>
