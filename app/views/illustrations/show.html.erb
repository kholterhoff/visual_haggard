<% content_for :title, @illustration.name %>
<%
  edition = @illustration.edition
  original_source = @illustration.display_image_source(style: :original)
  illustration_artist = @illustration.illustrator&.name.presence || @illustration.artist
%>

<div class="illustration-page" data-pagefind-body>
  <%= pagefind_record_data(
    filters: { record_type: "illustration" },
    meta: {
      record_type: "illustration",
      title: @illustration.name,
      novel_name: @illustration.novel.name,
      edition_title: edition.display_title,
      illustrator_name: illustration_artist,
      image: public_asset_url(original_source),
      summary: plain_text_excerpt(@illustration.description, length: 220),
      publication_citation: edition.publication_citation
    },
    body: [
      @illustration.description,
      @illustration.tag_list.join(" "),
      illustration_artist,
      @illustration.page_number,
      edition.display_title,
      edition.publisher,
      edition.publication_date,
      edition.publication_city,
      edition.source,
      @illustration.novel.name
    ]
  ) %>

  <div class="page-shell">
    <section class="record-header record-header--breadcrumbs-only">
      <p class="record-breadcrumbs">
        <%= link_to "Novels", novels_path %>
        /
        <%= linked_novel_title(@illustration.novel) %>
        /
        <%= link_to edition.display_title, edition_path(edition) %>
        /
        Illustration
      </p>
    </section>

    <section class="record-layout">
      <div class="record-figure">
        <% if original_source.present? %>
          <% original_url = public_asset_url(original_source) %>
          <figure class="illustration-lightbox" data-controller="photoswipe">
            <%= zoomable_image_link original_source,
              alt: @illustration.name,
              link_options: { class: "illustration-lightbox-link" } %>

            <figcaption class="illustration-original-link">
              <%= link_to "Open original", original_url, target: "_blank", rel: "noopener noreferrer", class: "section-link" %>
            </figcaption>
          </figure>
        <% else %>
          <div class="record-placeholder">No image available</div>
        <% end %>
      </div>

      <aside class="record-meta">
        <h1 class="sr-only"><%= @illustration.name %></h1>

        <dl>
          <% if @illustration.illustrator.present? %>
            <dt>Illustrator</dt>
            <dd><%= link_to @illustration.illustrator.name, illustrator_path(@illustration.illustrator) %></dd>
          <% elsif @illustration.artist.present? %>
            <dt>Illustrator</dt>
            <dd><%= @illustration.artist %></dd>
          <% end %>

          <dt>Title</dt>
          <dd><%= @illustration.name %></dd>

          <dt>Novel</dt>
          <dd><%= linked_novel_title(@illustration.novel) %></dd>

          <dt>Edition</dt>
          <dd><%= link_to edition.display_title, edition_path(edition) %></dd>

          <% if edition.publication_city.present? && edition.publication_city != "Unknown" %>
            <dt>Publication City</dt>
            <dd><%= edition.publication_city %></dd>
          <% end %>

          <% if edition.publisher.present? && edition.publisher != "Unknown" %>
            <dt>Published by</dt>
            <dd><%= edition.publisher %></dd>
          <% end %>

          <% if edition.publication_date.present? && edition.publication_date != "Unknown" %>
            <dt>Year Published</dt>
            <dd><%= edition.publication_date %></dd>
          <% end %>

          <% if @illustration.page_number.present? %>
            <dt>Page</dt>
            <dd><%= @illustration.page_number %></dd>
          <% end %>

          <% if edition.source.present? && edition.source != "Unknown" %>
            <dt>Edition Source</dt>
            <dd><%= edition.source %></dd>
          <% end %>

          <% if @illustration.description.present? %>
            <dt>Description</dt>
            <dd><%= normalized_simple_format(@illustration.description) %></dd>
          <% end %>

          <% if @illustration.internet_archive_link.present? %>
            <dt>Archive</dt>
            <dd><%= link_to "Internet Archive", @illustration.internet_archive_link, target: "_blank", rel: "noreferrer" %></dd>
          <% end %>
        </dl>
      </aside>
    </section>

    <% if @identical_illustrations.any? %>
      <section class="surface-panel illustrations-grid-panel illustration-identical-images" aria-labelledby="identical-images-heading">
        <div class="illustration-identical-images-header">
          <p class="page-eyebrow">Variant images</p>
          <h2 id="identical-images-heading">Other variants in the archive</h2>
        </div>

        <div class="illustrations-grid-page">
          <% @identical_illustrations.each do |illustration| %>
            <% image_source = illustration.display_image_source(style: :original) %>
            <article class="illustration-card">
              <% if image_source.present? %>
                <%= link_to illustration_path(illustration), class: "illustration-card-image-link" do %>
                  <div class="illustration-card-image-frame">
                    <%= image_tag image_source, alt: illustration.name, loading: "lazy", decoding: "async" %>
                  </div>
                <% end %>
              <% else %>
                <div class="illustration-card-image-frame">
                  <div class="illustration-card-placeholder">No image</div>
                </div>
              <% end %>

              <div class="illustration-card-body">
                <p class="illustration-card-kicker">Variant image</p>
                <h2><%= link_to illustration.name, illustration_path(illustration), class: "illustration-card-title-link" %></h2>
                <p class="illustration-card-meta"><%= link_to illustration.edition.display_title, edition_path(illustration.edition) %></p>
                <p class="illustration-card-meta"><%= linked_novel_title(illustration.novel) %></p>
                <% if illustration.page_number.present? %>
                  <p class="illustration-card-meta">Page <%= illustration.page_number %></p>
                <% end %>
              </div>
            </article>
          <% end %>
        </div>
      </section>
    <% end %>

    <div class="record-back-link">
      <%= link_to safe_join([content_tag(:span, safe_join(["Back to".html_safe, "&nbsp;".html_safe]), class: "record-back-label"), work_title(@illustration.novel.name)]), novel_path(@illustration.novel, anchor: "illustration-archive"), class: "ui-button ui-button--secondary" %>
    </div>
  </div>
</div>
