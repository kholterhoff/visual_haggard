<% content_for :title, @novel.name %>
<%
  visible_editions = @novel.visible_editions.to_a.sort_by(&:publication_sort_key)
  visible_illustrations = visible_editions.flat_map(&:illustrations)
  all_illustrations = visible_illustrations.select do |illustration|
    illustration.display_image_source(style: :original).present?
  end
  novel_illustrator_groups = visible_illustrations
    .select(&:illustrator)
    .group_by(&:illustrator)
    .sort_by { |illustrator, _| illustrator.directory_sort_key }
  cover_entries = @novel.cover_carousel_entries(style: :original, limit: 5)
  hero_cover_source = cover_entries.first&.dig(:source) || @novel.display_cover_source(style: :original)
  novel_cover_carousel_entries = cover_entries.map do |entry|
    edition = entry[:edition]
    illustration = entry[:illustration]
    cover_label = illustration&.page_number.presence || (illustration.present? ? "Dust jacket" : "Cover")

    {
      source: entry[:source],
      path: edition_path(edition),
      alt: "#{@novel.name} - #{edition.display_title}",
      eyebrow: cover_label,
      title: edition.display_title,
      meta: edition.publication_citation.presence || "Edition record",
      dot_label: "#{edition.display_title} cover"
    }
  end
%>

<div
  class="novel-page"
  data-pagefind-body
  <% if all_illustrations.size > 12 %>
    data-controller="back-to-top"
    data-back-to-top-minimum-items-value="12"
    data-back-to-top-row-threshold-value="4"
  <% end %>
>
  <%= pagefind_record_data(
    filters: { record_type: "novel" },
    meta: {
      record_type: "novel",
      title: @novel.name,
      novel_name: @novel.name,
      image: public_asset_url(hero_cover_source),
      summary: plain_text_excerpt(@novel.description, length: 220)
    },
    body: [@novel.description, @novel.tag_list.join(" ")]
  ) %>

  <div class="page-shell">
    <section class="novel-hero surface-panel">
      <div class="hero-image hero-image--carousel">
        <%= render "shared/archive_cover_carousel",
          entries: novel_cover_carousel_entries,
          aria_label: "Cover and dust jacket carousel for #{@novel.name}",
          empty_message: "No cover or dust jacket is currently available for this novel." %>
      </div>

      <div class="hero-content">
        <p class="page-eyebrow">Novel record</p>
        <h1 class="page-title novel-title"><%= work_title(@novel.name) %></h1>

        <div class="meta-chip-row novel-meta-row">
          <%= link_to pluralize(visible_editions.size, "edition"), "#edition-archive", class: "meta-chip meta-chip-link" %>
          <%= link_to pluralize(novel_illustrator_groups.size, "illustrator"), "#illustrator-archive", class: "meta-chip meta-chip-link" %>
          <%= link_to pluralize(all_illustrations.size, "illustration"), "#illustration-archive", class: "meta-chip meta-chip-link" %>
          <% if @novel.blog_posts.any? %>
            <%= link_to pluralize(@novel.blog_posts.size, "related essay"), "#related-essays", class: "meta-chip meta-chip-link" %>
          <% end %>
        </div>

        <% if @novel.description.present? %>
          <div class="novel-description">
            <%= normalized_simple_format(@novel.description) %>
          </div>
        <% end %>

        <% if @novel.tag_list.any? %>
          <div class="novel-tags">
            <% @novel.tag_list.each do |tag| %>
              <span class="tag"><%= tag %></span>
            <% end %>
          </div>
        <% end %>

        <% if @novel.blog_posts.any? %>
          <div class="further-reading" id="related-essays">
            <p class="page-eyebrow">Further reading</p>
            <ul>
              <% @novel.blog_posts.each do |post| %>
                <li>
                  <%= link_to post.title, blog_post_path(post) %>
                  <% if post.author.present? %>
                    <span class="post-author">by <%= post.author %></span>
                  <% end %>
                </li>
              <% end %>
            </ul>
          </div>
        <% end %>
      </div>
    </section>

    <% if visible_editions.any? %>
      <section class="surface-panel novel-section" id="edition-archive">
        <div class="section-heading">
          <div>
            <p class="page-eyebrow">Edition archive</p>
            <h2>Editions of <%= work_title(@novel.name) %></h2>
          </div>
        </div>

        <div class="editions-grid">
          <% visible_editions.each do |edition| %>
            <% cover_source = edition.display_cover_source(style: :original) %>
            <% if cover_source.blank? %>
              <% lead_illustration = edition.illustrations.find { |illustration| illustration.display_image_source(style: :original).present? } %>
              <% cover_source = lead_illustration&.display_image_source(style: :original) %>
            <% end %>
            <article class="edition-card">
              <%= link_to edition_path(edition), class: "edition-link" do %>
                <div class="edition-thumbnail">
                  <% if cover_source.present? %>
                    <%= image_tag cover_source, alt: edition.display_title, loading: "lazy", decoding: "async" %>
                  <% else %>
                    <div class="placeholder-thumbnail">No image</div>
                  <% end %>
                </div>
                <div class="edition-info">
                  <p class="edition-label">Edition</p>
                  <h3><%= edition.display_title %></h3>
                  <% if (citation = edition.publication_citation) %>
                    <p class="edition-details"><%= citation %></p>
                  <% end %>
                </div>
              <% end %>
            </article>
          <% end %>
        </div>
      </section>
    <% end %>

    <% if novel_illustrator_groups.any? %>
      <section class="surface-panel novel-section" id="illustrator-archive">
        <div class="section-heading">
          <div>
            <p class="page-eyebrow">Illustrator archive</p>
            <h2>Illustrators of <%= work_title(@novel.name) %></h2>
          </div>
        </div>

        <div class="novel-illustrators-grid">
          <% novel_illustrator_groups.each do |illustrator, illustrations| %>
            <% representative_illustration = illustrations.find { |illustration| illustration.display_image_source(style: :original).present? } || illustrations.first %>
            <% representative_source = representative_illustration&.display_image_source(style: :original) %>
            <article class="novel-illustrator-card">
              <%= link_to illustrator_path(illustrator), class: "novel-illustrator-link" do %>
                <div class="novel-illustrator-thumbnail">
                  <% if representative_source.present? %>
                    <%= image_tag representative_source,
                      alt: "Illustration by #{illustrator.name} from #{@novel.name}",
                      loading: "lazy",
                      decoding: "async" %>
                  <% else %>
                    <div class="placeholder-thumbnail">No image</div>
                  <% end %>
                </div>
                <div class="novel-illustrator-copy">
                  <p class="novel-illustrator-label">Illustrator</p>
                  <h3><%= illustrator.name %></h3>
                  <p class="novel-illustrator-meta"><%= pluralize(illustrations.size, "illustration") %> in this novel</p>
                </div>
              <% end %>
            </article>
          <% end %>
        </div>
      </section>
    <% end %>

    <% if all_illustrations.any? %>
      <section class="surface-panel novel-section" id="illustration-archive">
        <div class="section-heading">
          <div>
            <p class="page-eyebrow">Illustration archive</p>
            <h2>Illustrations from <%= work_title(@novel.name) %></h2>
          </div>
        </div>

        <div class="illustrations-grid">
          <% all_illustrations.each do |illustration| %>
            <article class="illustration-tile" data-back-to-top-target="item">
              <%= link_to illustration_path(illustration), class: "illustration-tile-link" do %>
                <div class="illustration-thumbnail">
                  <%= image_tag illustration.display_image_source(style: :original),
                    alt: illustration.name.presence || "Illustration from #{@novel.name}",
                    loading: "lazy",
                    decoding: "async" %>
                </div>
                <div class="illustration-tile-copy">
                  <p class="illustration-tile-label">Illustration</p>
                  <h3><span class="illustration-tile-title"><%= illustration.name.presence || "Untitled illustration" %></span></h3>
                </div>
              <% end %>
            </article>
          <% end %>
        </div>
      </section>
    <% end %>

    <div class="record-back-link">
      <%= link_to "Back to novels", novels_path, class: "ui-button ui-button--secondary" %>
    </div>

    <% if all_illustrations.size > 12 %>
      <button
        type="button"
        class="ui-button ui-button--secondary back-to-top-button"
        data-back-to-top-target="button"
        data-action="back-to-top#scroll"
        hidden
      >
        Back to top
      </button>
    <% end %>
  </div>
</div>
