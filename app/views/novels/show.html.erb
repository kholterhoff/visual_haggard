<% content_for :title, @novel.name %>
<%
  visible_editions = @novel.editions.reject(&:synthetic_placeholder?)
  all_illustrations = visible_editions.flat_map(&:illustrations).select do |illustration|
    illustration.display_image_source(style: :original).present?
  end
  hero_edition = @novel.lead_cover_edition(style: :original)
  hero_illustration = @novel.lead_illustration(style: :original)
  hero_cover_source = @novel.display_cover_source(style: :original)
%>

<div class="novel-page" data-pagefind-body>
  <%= pagefind_record_data(
    filters: { record_type: "novel" },
    meta: {
      record_type: "novel",
      title: @novel.name,
      novel_name: @novel.name,
      image: public_asset_url(hero_cover_source),
      summary: plain_text_excerpt(@novel.description, length: 220)
    },
    body: [@novel.description, @novel.tag_list.join(" ")]
  ) %>

  <div class="page-shell">
    <section class="novel-hero surface-panel">
      <div class="hero-image">
        <% if hero_edition %>
          <%= image_tag hero_edition.display_cover_source(style: :original), alt: "#{@novel.name} cover", decoding: "async" %>
        <% elsif hero_illustration %>
          <div data-controller="photoswipe">
            <%= zoomable_image_link hero_illustration.display_image_source(style: :original),
              alt: "Illustration from #{@novel.name}" %>
          </div>
        <% else %>
          <div class="record-placeholder">No illustration available</div>
        <% end %>
      </div>

      <div class="hero-content">
        <p class="page-eyebrow">Novel record</p>
        <h1 class="page-title novel-title"><%= @novel.name %></h1>

        <div class="meta-chip-row novel-meta-row">
          <%= link_to pluralize(visible_editions.size, "edition"), "#edition-archive", class: "meta-chip meta-chip-link" %>
          <%= link_to pluralize(all_illustrations.size, "illustration"), "#illustration-archive", class: "meta-chip meta-chip-link" %>
          <% if @novel.blog_posts.any? %>
            <%= link_to pluralize(@novel.blog_posts.size, "related essay"), "#related-essays", class: "meta-chip meta-chip-link" %>
          <% end %>
        </div>

        <% if @novel.description.present? %>
          <div class="novel-description">
            <%= normalized_simple_format(@novel.description) %>
          </div>
        <% end %>

        <% if @novel.tag_list.any? %>
          <div class="novel-tags">
            <% @novel.tag_list.each do |tag| %>
              <span class="tag"><%= tag %></span>
            <% end %>
          </div>
        <% end %>

        <% if @novel.blog_posts.any? %>
          <div class="further-reading" id="related-essays">
            <p class="page-eyebrow">Further reading</p>
            <ul>
              <% @novel.blog_posts.each do |post| %>
                <li>
                  <%= link_to post.title, blog_post_path(post) %>
                  <% if post.author.present? %>
                    <span class="post-author">by <%= post.author %></span>
                  <% end %>
                </li>
              <% end %>
            </ul>
          </div>
        <% end %>
      </div>
    </section>

    <% if visible_editions.any? %>
      <section class="surface-panel novel-section" id="edition-archive">
        <div class="section-heading">
          <div>
            <p class="page-eyebrow">Edition archive</p>
            <h2>Editions of <%= @novel.name %></h2>
          </div>
        </div>

        <div class="editions-grid">
          <% visible_editions.sort_by { |edition| edition.publication_date.to_s }.each do |edition| %>
            <% cover_source = edition.display_cover_source(style: :original) %>
            <% if cover_source.blank? %>
              <% lead_illustration = edition.illustrations.find { |illustration| illustration.display_image_source(style: :original).present? } %>
              <% cover_source = lead_illustration&.display_image_source(style: :original) %>
            <% end %>
            <article class="edition-card">
              <%= link_to edition_path(edition), class: "edition-link" do %>
                <div class="edition-thumbnail">
                  <% if cover_source.present? %>
                    <%= image_tag cover_source, alt: edition.display_title, loading: "lazy", decoding: "async" %>
                  <% else %>
                    <div class="placeholder-thumbnail">No image</div>
                  <% end %>
                </div>
                <div class="edition-info">
                  <p class="edition-label">Edition</p>
                  <h3><%= edition.display_title %></h3>
                  <% if (citation = edition.publication_citation) %>
                    <p class="edition-details"><%= citation %></p>
                  <% end %>
                </div>
              <% end %>
            </article>
          <% end %>
        </div>
      </section>
    <% end %>

    <% if all_illustrations.any? %>
      <section class="surface-panel novel-section" id="illustration-archive">
        <div class="section-heading">
          <div>
            <p class="page-eyebrow">Illustration archive</p>
            <h2>Illustrations from <%= @novel.name %></h2>
          </div>
        </div>

        <div class="illustrations-grid" data-controller="photoswipe">
          <% all_illustrations.each do |illustration| %>
            <article class="illustration-tile">
              <div class="illustration-tile-link">
                <div class="illustration-thumbnail">
                  <%= zoomable_image_link illustration.display_image_source(style: :original),
                    link_options: { class: "illustration-zoom-link" } do %>
                    <%= image_tag illustration.display_image_source(style: :original),
                      alt: illustration.name.presence || "Illustration from #{@novel.name}",
                      loading: "lazy",
                      decoding: "async" %>
                  <% end %>
                </div>
                <div class="illustration-tile-copy">
                  <p class="illustration-tile-label">Illustration</p>
                  <h3><%= link_to illustration.name.presence || "Untitled illustration", illustration_path(illustration) %></h3>
                </div>
              </div>
            </article>
          <% end %>
        </div>
      </section>
    <% end %>

    <div class="record-back-link">
      <%= link_to "Back to novels", novels_path, class: "ui-button ui-button--secondary" %>
    </div>
  </div>
</div>
