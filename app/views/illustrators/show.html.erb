<% content_for :title, @illustrator.name %>
<%
  carousel_entries = @illustrator.showcase_carousel_entries(style: :original, limit: 5)
  hero_image = carousel_entries.first&.dig(:source) || @illustrator.representative_image_source(style: :original)
  illustrator_cover_carousel_entries = carousel_entries.map do |entry|
    illustration = entry[:illustration]
    edition = entry[:edition]
    novel = entry[:novel]
    entry_type = entry[:entry_type]
    meta_parts = [
      novel_work_title(novel),
      edition.publication_citation.presence
    ].compact

    title =
      case entry_type
      when :illustration
        illustration&.name.presence || "Untitled illustration"
      else
        formatted_edition_title(edition)
      end

    eyebrow =
      case entry_type
      when :illustration
        illustration&.page_number.presence || "Illustration"
      when :edition_cover
        "Edition cover"
      else
        illustration&.cover_related? ? illustration.page_number.presence || "Cover art" : "Cover art"
      end

    path =
      case entry_type
      when :illustration
        illustration_path(illustration)
      else
        edition_path(edition)
      end

    alt =
      case entry_type
      when :illustration
        illustration&.name.presence || "#{@illustrator.name} illustration from #{novel.name}"
      when :edition_cover
        "#{novel.name} edition cover"
      else
        "#{@illustrator.name} cover art for #{novel.name}"
      end

    dot_label =
      case entry_type
      when :illustration
        "#{novel.display_title_text(short: true)}, #{illustration&.name.presence || "illustration"}"
      else
        "#{novel.display_title_text(short: true)}, #{edition.display_title}"
      end

    {
      source: entry[:source],
      path: path,
      alt: alt,
      eyebrow: eyebrow,
      title: title,
      meta: safe_join(meta_parts, " &middot; ".html_safe),
      dot_label: dot_label
    }
  end
%>

<div
  class="illustrator-show-page"
  data-pagefind-body
  data-controller="back-to-top"
  data-back-to-top-minimum-items-value="12"
  data-back-to-top-row-threshold-value="4"
  data-back-to-top-scroll-threshold-value="720"
>
  <%= pagefind_record_data(
    filters: { record_type: "illustrator" },
    meta: {
      record_type: "illustrator",
      title: @illustrator.name,
      illustrator_name: @illustrator.name,
      image: public_asset_url(hero_image),
      summary: plain_text_excerpt(@illustrator.bio, length: 220),
      summary_html: search_excerpt_html(@illustrator.bio, length: 220)
    },
    body: [@illustrator.bio]
  ) %>

  <div class="page-shell">
    <section class="illustrator-show-hero surface-panel">
      <div class="illustrator-show-copy">
        <p class="page-eyebrow">Illustrator record</p>
        <h1 class="page-title"><%= @illustrator.name %></h1>
        <% if @illustrator.bio.present? %>
          <div class="illustrator-bio">
            <%= normalized_simple_format(@illustrator.bio) %>
          </div>
        <% else %>
          <p class="illustrator-bio-fallback">No biographical note is currently available for this illustrator.</p>
        <% end %>
      </div>

      <div class="illustrator-show-image">
        <div class="illustrator-show-image-frame illustrator-show-image-frame--carousel">
          <%= render "shared/archive_cover_carousel",
            entries: illustrator_cover_carousel_entries,
            aria_label: "Illustrated works carousel for #{@illustrator.name}",
            empty_message: "No cover or illustration is currently available for this illustrator." %>
        </div>
      </div>
    </section>

    <% if @illustrations.any? %>
      <section class="surface-panel illustrator-work-section" id="illustrator-work-archive">
        <div class="section-heading">
          <div>
            <h2><%= @illustrations.size %> <%= "Illustration".pluralize(@illustrations.size) %> by <%= @illustrator.name %></h2>
          </div>
        </div>

        <div class="meta-chip-row illustrator-work-jumps">
          <% @illustration_groups.each do |group| %>
            <%= link_to "##{group[:anchor_id]}", class: "meta-chip meta-chip-link", aria: { label: "#{group[:novel].name}: #{pluralize(group[:illustrations].size, "illustration")}" } do %>
              <%= novel_work_title(group[:novel], short: true) %>
            <% end %>
          <% end %>
        </div>

        <div class="illustrator-work-groups">
          <% @illustration_groups.each do |group| %>
            <section class="illustrator-work-group" id="<%= group[:anchor_id] %>">
              <div class="section-heading illustrator-work-group-heading">
                <div>
                  <p class="page-eyebrow"><%= group[:novel].record_label %></p>
                  <h3>Illustrations from <%= novel_work_title(group[:novel]) %></h3>
                </div>
              </div>

              <div class="illustrator-work-grid" data-controller="photoswipe">
                <% group[:illustrations].each do |illustration| %>
                  <% edition = illustration.edition %>
                  <% novel = group[:novel] %>
                  <% edition_label = condensed_edition_label(edition, novel:) %>
                  <article class="illustrator-work-card" data-back-to-top-target="item">
                    <%= link_to illustration_path(illustration), class: "illustrator-work-link" do %>
                      <div class="illustrator-work-image-frame">
                        <% if (image_source = illustration.display_image_source(style: :original)).present? %>
                          <%= image_tag image_source,
                            alt: illustration.name,
                            class: "illustrator-work-image",
                            loading: "lazy",
                            decoding: "async" %>
                        <% else %>
                          <div class="illustrator-grid-placeholder">No image available</div>
                        <% end %>
                      </div>
                      <div class="illustrator-work-copy">
                        <p class="illustrator-card-kicker">Illustration</p>
                        <h4><span class="illustrator-work-title"><%= illustration.name.presence || "Untitled illustration" %></span></h4>
                        <p><strong><%= novel_work_title(novel) %></strong></p>
                        <% if edition_label.present? %>
                          <p><%= formatted_edition_label(edition_label) %></p>
                        <% end %>
                      </div>
                    <% end %>
                  </article>
                <% end %>
              </div>
            </section>
          <% end %>
        </div>
      </section>
    <% end %>

    <button
      type="button"
      class="ui-button ui-button--secondary back-to-top-button"
      data-back-to-top-target="button"
      data-action="back-to-top#scroll"
      hidden
    >
      Back to top
    </button>
  </div>
</div>
