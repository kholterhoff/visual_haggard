<% content_for :title, "Illustrators" %>

<div class="illustrators-page">
  <div class="page-shell">
    <section class="page-hero illustrators-hero">
      <div>
        <p class="page-eyebrow">Illustrators</p>
        <h1 class="page-title">Discover the artists who shaped Haggard's fiction.</h1>
        <p class="page-lead">Move from each illustrator to the novels, editions, and images that define their contribution to the archive.</p>

        <div class="meta-chip-row illustrators-hero-meta">
          <% if @illustrator_groups.any? %>
            <%= link_to "Directory", "#illustrator-directory", class: "meta-chip meta-chip-link" %>
          <% end %>
          <% if @illustrators.any? %>
            <%= link_to "Artist browse", "#illustrator-archive-browse", class: "meta-chip meta-chip-link" %>
          <% end %>
        </div>
      </div>
    </section>

    <section class="surface-panel illustrator-directory" id="illustrator-directory">
      <div class="section-heading">
        <div>
          <p class="page-eyebrow">Directory</p>
          <h2>Browse by last-name initial</h2>
        </div>
      </div>

      <div class="illustrator-directory-jump" aria-label="Alphabetical jump navigation">
        <% @illustrator_groups.keys.sort.each do |letter| %>
          <%= link_to letter, "#illustrator-letter-#{letter.parameterize}", class: "illustrator-letter-jump" %>
        <% end %>
      </div>

      <div class="illustrator-directory-groups">
        <% @illustrator_groups.keys.sort.each do |letter| %>
          <section class="illustrator-directory-group" id="illustrator-letter-<%= letter.parameterize %>">
            <header class="illustrator-directory-group-header">
              <h3><%= letter %></h3>
            </header>

            <div class="illustrator-directory-links">
              <% @illustrator_groups.fetch(letter).each do |illustrator| %>
                <%= link_to illustrator_path(illustrator), class: "illustrator-link" do %>
                  <span class="illustrator-link-last-name"><%= illustrator.directory_last_name %></span>
                  <span class="illustrator-link-full-name"><%= illustrator.name %></span>
                <% end %>
              <% end %>
            </div>
          </section>
        <% end %>
      </div>
    </section>

    <section class="surface-panel illustrator-grid-panel" id="illustrator-archive-browse">
      <div class="section-heading">
        <div>
          <p class="page-eyebrow">Artist browse</p>
          <h2>Representative works</h2>
        </div>
      </div>

      <div class="illustrator-grid" data-controller="photoswipe">
        <% @illustrators.each do |illustrator| %>
          <% representative_illustration = illustrator.representative_illustration(style: :original) %>
          <% preview_image = illustrator.representative_image_source(style: :original) %>
          <article class="illustrator-grid-card">
            <div class="illustrator-grid-image-link">
              <div class="illustrator-grid-image-frame">
                <% if preview_image.present? %>
                  <%= zoomable_image_link preview_image, link_options: { class: "illustrator-zoom-link" } do %>
                    <%= image_tag preview_image,
                      alt: "Representative illustration by #{illustrator.name}",
                      class: "illustrator-grid-image",
                      loading: "lazy",
                      decoding: "async" %>
                  <% end %>
                <% else %>
                  <div class="illustrator-grid-placeholder">No image available</div>
                <% end %>
              </div>

              <div class="illustrator-grid-copy">
                <p class="illustrator-card-kicker">Illustrator</p>
                <h3><%= link_to illustrator.name, illustrator_path(illustrator) %></h3>
              </div>
            </div>
          </article>
        <% end %>
      </div>
    </section>
  </div>
</div>
