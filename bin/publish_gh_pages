#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BRANCH="${PAGES_BRANCH:-gh-pages}"
REMOTE="${PAGES_REMOTE:-origin}"
WORKTREE_PATH="${PAGES_WORKTREE:-${ROOT_DIR%/*}/visual_haggard_pages}"
STATIC_HOST_VALUE="${STATIC_HOST:-www.visualhaggard.org}"
CUSTOM_DOMAIN_VALUE="${CUSTOM_DOMAIN:-www.visualhaggard.org}"
RUN_EXPORT="${RUN_EXPORT:-true}"
PAGEFIND_CMD_VALUE="${PAGEFIND_CMD:-npx --yes pagefind}"
COMMIT_MESSAGE="${PAGES_COMMIT_MESSAGE:-Publish archive update $(date -u +%Y-%m-%dT%H:%M:%SZ)}"

cd "$ROOT_DIR"

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "Not inside a git repository." >&2
  exit 1
fi

if ! git rev-parse --verify HEAD >/dev/null 2>&1; then
  echo "Create and commit the main branch before publishing gh-pages." >&2
  exit 1
fi

if ! git remote get-url "$REMOTE" >/dev/null 2>&1; then
  echo "Add the $REMOTE remote before publishing gh-pages." >&2
  exit 1
fi

if [[ "$RUN_EXPORT" == "true" ]]; then
  CUSTOM_DOMAIN="$CUSTOM_DOMAIN_VALUE" STATIC_HOST="$STATIC_HOST_VALUE" PAGEFIND_CMD="$PAGEFIND_CMD_VALUE" bin/rails static:export
fi

if [[ ! -d "$ROOT_DIR/dist" ]]; then
  echo "Static export output was not found at $ROOT_DIR/dist." >&2
  exit 1
fi

REPORT_PATH="$ROOT_DIR/dist/static_export_report.txt"
if [[ -f "$REPORT_PATH" ]] && grep -Eq "Pagefind indexing failed|Pagefind binary not found" "$REPORT_PATH"; then
  echo "Pagefind indexing failed during static export; aborting publish so archive search is not deployed in a broken state." >&2
  exit 1
fi

if [[ -e "$WORKTREE_PATH/.git" || -f "$WORKTREE_PATH/.git" ]]; then
  git -C "$WORKTREE_PATH" rev-parse --is-inside-work-tree >/dev/null 2>&1
else
  if git show-ref --verify --quiet "refs/heads/$BRANCH"; then
    git worktree add "$WORKTREE_PATH" "$BRANCH"
  elif git ls-remote --exit-code --heads "$REMOTE" "$BRANCH" >/dev/null 2>&1; then
    git fetch "$REMOTE" "$BRANCH:$BRANCH"
    git worktree add "$WORKTREE_PATH" "$BRANCH"
  else
    git worktree add -b "$BRANCH" "$WORKTREE_PATH"
  fi
fi

rsync -a --delete --exclude '.git' "$ROOT_DIR/dist/" "$WORKTREE_PATH/"

if [[ -n "$CUSTOM_DOMAIN_VALUE" ]]; then
  printf '%s\n' "$CUSTOM_DOMAIN_VALUE" > "$WORKTREE_PATH/CNAME"
else
  rm -f "$WORKTREE_PATH/CNAME"
fi

touch "$WORKTREE_PATH/.nojekyll"

git -C "$WORKTREE_PATH" add -A

if git -C "$WORKTREE_PATH" diff --cached --quiet; then
  echo "No publishable changes in gh-pages."
  exit 0
fi

git -C "$WORKTREE_PATH" commit -m "$COMMIT_MESSAGE"
git -C "$WORKTREE_PATH" push "$REMOTE" "$BRANCH"

echo "Published static site to $REMOTE/$BRANCH via $WORKTREE_PATH"
