#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

cd "$ROOT_DIR"

paths=(
  "public/assets"
  "tmp/cache/assets"
  "dist"
)

for path in "${paths[@]}"; do
  if [[ -e "$path" ]]; then
    rm -rf "$path"
    echo "Removed $path"
  else
    echo "Skipped $path (not present)"
  fi
done

cat <<'EOF'

Local generated assets were cleared.
Next steps:
1. Restart `bin/rails server`
2. Hard refresh the browser
3. Re-run `bin/publish_gh_pages` when you want a fresh static build
EOF
