# Environment Variables for Visual Haggard

# Database
DATABASE_URL=postgresql://localhost/visual_haggard_production

# Rails
SECRET_KEY_BASE=your_secret_key_base_here
RAILS_ENV=production

# AWS S3 Configuration (Production Only)
# Get these from AWS IAM after creating an S3 bucket
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
S3_BUCKET=visual-haggard-production

# Optional: Custom domain for assets
# ASSET_HOST=https://assets.visualhaggard.org